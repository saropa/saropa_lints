      },
      {
        "view": "saropaLints.logs",
        "contents": "Saropa Lints is **off** for this workspace.\n\n[Enable Saropa Lints](command:saropaLints.enable)",
        "when": "!saropaLints.enabled"
      },
      {
        "view": "saropaLints.suggestions",
        "contents": "Run analysis to get suggestions.\n\n[Run Analysis](command:saropaLints.runAnalysis)",
