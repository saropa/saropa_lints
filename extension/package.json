        "when": "!saropaLints.enabled"
      },
      {
        "view": "saropaLints.overview",
        "contents": "No analysis yet.\n\n[Run Analysis](command:saropaLints.runAnalysis)",
        "when": "saropaLints.enabled && !saropaLints.hasViolations"
