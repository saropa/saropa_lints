#!/bin/sh
# Only human authors as contributors on GitHub. Reject commit messages that credit tools or AI.
# Enable: git config core.hooksPath .githooks

msg_file="$1"
msg=$(cat "$msg_file")

blocked() {
  echo "commit-msg: Only human authors should be contributors on GitHub." >&2
  echo "Remove Co-Authored-By (Claude/Anthropic), Made-with: Cursor, and 'Generated with' lines." >&2
  exit 1
}

# Block trailers/lines that credit tools or AI (case-insensitive where it matters)
echo "$msg" | grep -qEi '^Made-with:\s*Cursor' && blocked
echo "$msg" | grep -qE '^Co-Authored-By:.*[Cc]laude' && blocked
echo "$msg" | grep -qE '^Co-Authored-By:.*[Aa]nthropic' && blocked
echo "$msg" | grep -qEi '^Co-Authored-By:.*noreply@anthropic' && blocked
echo "$msg" | grep -qEi '^Co-Authored-By:.*(Cursor|Copilot|GPT|OpenAI|noreply@github)' && blocked
echo "$msg" | grep -qEi '^Generated with.*(Cursor|Claude)' && blocked

exit 0
